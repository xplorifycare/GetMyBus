# =========================================================================
# GETMYBUS LANDING PAGE - ENVIRONMENT VARIABLES CONFIGURATION
# Copy this file to '.env.local' and add your secrets to activate lead delivery.
# =========================================================================

# -------------------------------------------------------------------------
# ✉️ OPTION 1: EMAIL DELIVERY VIA WEB3FORMS (Zero Setup & Free)
# -------------------------------------------------------------------------
# Get your free Access Key instantly by entering your email at: https://web3forms.com
# Any form submission will automatically be forwarded to your registered email inbox.
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# -------------------------------------------------------------------------
# 💬 OPTION 2: SLACK NOTIFICATION
# -------------------------------------------------------------------------
# Create an Incoming Webhook URL in your Slack workspace settings (e.g. #leads channel)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXXX/YYYYYY/ZZZZZZ

# -------------------------------------------------------------------------
# 👾 OPTION 3: DISCORD NOTIFICATION
# -------------------------------------------------------------------------
# Create a Webhook inside a Discord channel integration settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1234567890/abcde_fg_hijk
